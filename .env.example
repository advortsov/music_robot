# ============================================
# Bluetooth Music Randomizer - Пример конфигурации
# Скопируйте этот файл в .env и заполните своими значениями
# ============================================

BT_MAC="XX:XX:XX:XX:XX:XX"
MEDIA_FILE="/storage/emulated/0/Music/track.mp3"
LOG_DIR="logs"
TIME_WINDOW_START="14:00"
TIME_WINDOW_END="19:00"
NUM_SESSIONS=5
SESSION_DURATION_SEC=60
PAUSE_BETWEEN_MIN_MIN=10
PAUSE_BETWEEN_MAX_MIN=45
VOLUME_LEVEL=70
SCHEDULE_MODE="random"
START_DELAY_MIN=0
DISABLE_BT_AFTER_SESSION=true
DEBUG_MODE=false