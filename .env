# ============================================
# Bluetooth Music Randomizer - Конфигурация
# ============================================

# ----- ОБЩИЕ НАСТРОЙКИ -----
# MAC-адрес Bluetooth колонки (узнать через: adb shell dumpsys bluetooth | grep -i "address")
BT_MAC="78:22:73:8B:47:59"

# Режим выбора музыки:
#   "single" - один конкретный файл (MEDIA_FILE)
#   "folder" - случайный файл из папки (MEDIA_FOLDER)
MUSIC_MODE="folder"

# Путь к файлу (если MUSIC_MODE="single")
MEDIA_FILE="/storage/emulated/0/Music/track.mp3"

# Путь к папке с аудиофайлами (если MUSIC_MODE="folder")
MEDIA_FOLDER="/storage/emulated/0/Download/crickets"

# Поддерживаемые расширения аудиофайлов
MEDIA_EXTENSIONS=".mp3,.wav,.m4a,.ogg,.flac"

# ----- ВРЕМЕННОЕ ОКНО -----
TIME_WINDOW_START="00:01"
TIME_WINDOW_END="23:59"
MIN_INTERVAL_BETWEEN_SEC=30

# ----- ПАРАМЕТРЫ ВКЛЮЧЕНИЙ -----
NUM_SESSIONS=50
SESSION_DURATION_SEC=60
PAUSE_BETWEEN_MIN_MIN=1
PAUSE_BETWEEN_MAX_MIN=20

# ----- ГРОМКОСТЬ -----
VOLUME_LEVEL=100

# ----- РЕЖИМЫ -----
SCHEDULE_MODE="random"
START_DELAY_MIN=0
DISABLE_BT_AFTER_SESSION=true
DEBUG_MODE=true